---

export interface Props {
  position?: "tr" | "tc" | "tl" | "rc" | "lc" | "cc" | "bc" | "br" | "bl"
}

const {position="tr"} = Astro.props

const positionClasses = {
  tl: "top-5 left-5",
  tc: "top-5 left-1/2 -translate-x-1/2",
  tr: "top-5 right-5",
  lc: "top-1/2 left-5 -translate-y-1/2",
  cc: "top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2",
  rc: "top-1/2 right-5 -translate-y-1/2",
  bl: "bottom-5 left-5",
  bc: "bottom-5 left-1/2 -translate-x-1/2",
  br: "bottom-5 right-5",
};

const currentPositionClass = positionClasses[position] || positionClasses.tr;
---

<div 
  id="toast-container"
  class={`fixed ${currentPositionClass} z-50 flex flex-col gap-4 w-full max-w-sm pointer-events-none`}
>
</div>

<svg width="0" height="0" class="absolute pointer-events-none" style="visibility: hidden;">
  <defs>
    <filter id="liquid-glass-refraction" x="-20%" y="-20%" width="140%" height="140%">
      <feTurbulence 
        type="fractalNoise" 
        baseFrequency="0.015 0.04" 
        numOctaves="2" 
        stitchTiles="stitch" 
        result="noise" 
      />
      <feDisplacementMap 
        in="SourceGraphic" 
        in2="noise" 
        scale="18" 
        xChannelSelector="R" 
        yChannelSelector="G" 
      />
    </filter>
  </defs>
</svg>

<script>
  interface ToastOptions {
    message: string;
    type?: 'success' | 'error' | 'info';
    duration?: number;
  }

  const MAX_TOASTS = 3;

  const toastConfig = {
    success: {
      bgColor: 'bg-white/10 border-white/20 text-emerald-500 dark:text-emerald-400',
      icon: `<svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>`
    },
    error: {
      bgColor: 'bg-white/10 border-white/20 text-rose-500 dark:text-rose-400',
      icon: `<svg class="w-5 h-5 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>`
    },
    info: {
      bgColor: 'bg-white/10 border-white/20 text-sky-500 dark:text-sky-400',
      icon: `<svg class="w-5 h-5 text-sky-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`
    }
  };

  function dismissToast(toast: HTMLElement) {
    if (!toast || toast.classList.contains('translate-x-full')) return;
    toast.classList.add('translate-x-full', 'opacity-0');
    toast.style.pointerEvents = 'none';
    
    const handleTransitionEnd = () => {
      toast.remove();
      toast.removeEventListener('transitionend', handleTransitionEnd);
    };
    toast.addEventListener('transitionend', handleTransitionEnd);
  }

  function createToast({ message, type = 'success', duration = 3000 }: ToastOptions) {
    const container = document.getElementById('toast-container');
    if (!container) return;

    const currentToasts = container.querySelectorAll('.liquid-toast-item');
    if (currentToasts.length >= MAX_TOASTS) {
      const oldestToast = currentToasts[0] as HTMLElement;
      dismissToast(oldestToast);
    }

    const config = toastConfig[type];
    const toast = document.createElement('div');
    
    // Mở khóa pointer-events-auto toàn bộ để nhận diện sự kiện Hover chuột
    toast.className = `liquid-toast-item pointer-events-auto relative flex items-center gap-3 w-full px-5 py-3 rounded-2xl border shadow-[0_8px_32px_0_rgba(0,0,0,0.08)] overflow-hidden transform translate-x-full opacity-0 transition-all duration-300 ease-out ${config.bgColor}`;
    
    toast.innerHTML = `
      <div class="liquid-bg absolute inset-0 -z-10 backdrop-blur-md pointer-events-none transform scale-105 bg-white/10 dark:bg-black/10"></div>
      <div class="absolute inset-x-0 top-0 h-1/2 bg-gradient-to-b from-white/10 to-transparent pointer-events-none mix-blend-overlay"></div>

      <div class="flex-shrink-0 flex items-center justify-center bg-white/20 dark:bg-white/5 p-1.5 rounded-xl border border-white/10 shadow-inner">
        ${config.icon}
      </div>
      
      <p class="text-xs leading-relaxed flex-1 tracking-wide font-medium drop-shadow-sm select-none">${message}</p>
      
      <button class="close-btn flex-shrink-0 text-gray-400 hover:text-gray-600 dark:text-white/40 dark:hover:text-white/80 transition-all p-1.5 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 cursor-pointer relative z-50" type="button">
        <svg class="w-4 h-4 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    `;

    container.appendChild(toast);

    requestAnimationFrame(() => {
      toast.classList.remove('translate-x-full', 'opacity-0');
    });

    // CƠ CHẾ HOVER PAUSE & RESUME CAO CẤP
    let timeLeft = duration;
    let startTimestamp = Date.now();
    let autoDismissTimeout: NodeJS.Timeout | number;

    const startTimer = () => {
      startTimestamp = Date.now();
      autoDismissTimeout = setTimeout(() => {
        dismissToast(toast);
      }, timeLeft);
    };

    const pauseTimer = () => {
      clearTimeout(autoDismissTimeout);
      // Tính toán lượng thời gian còn sót lại trước khi bị hover vào
      timeLeft -= Date.now() - startTimestamp;
      if (timeLeft < 0) timeLeft = 0;
    };

    // Đăng ký sự kiện vật lý lên thẻ Toast
    toast.addEventListener('mouseenter', pauseTimer);
    toast.addEventListener('mouseleave', () => {
      if (timeLeft > 0) startTimer();
    });

    // Kích hoạt bộ đếm thời gian tự hủy lần đầu tiên
    startTimer();

    // Sự kiện click nút X dập tắt toast ngay lập tức
    const closeBtn = toast.querySelector('.close-btn') as HTMLButtonElement;
    if (closeBtn) {
      closeBtn.onclick = (e) => {
        e.preventDefault();
        e.stopPropagation();
        clearTimeout(autoDismissTimeout);
        dismissToast(toast);
      };
    }
  }

  window.addEventListener('astro-toast', (event: Event) => {
    const customEvent = event as CustomEvent<ToastOptions>;
    if (customEvent.detail) {
      createToast(customEvent.detail);
    }
  });
</script>

<style is:global>
  .liquid-bg {
    filter: url(#liquid-glass-refraction);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
  }
</style>